# XP-Panel Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=xppanel
POSTGRES_USER=xppanel
POSTGRES_PASSWORD=changeme_use_strong_password

DATABASE_URL=postgres://xppanel:changeme_use_strong_password@postgres:5432/xppanel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=http://minio:9000

# ── PowerDNS ──────────────────────────────────────────────────────────────────
PDNS_API_KEY=pdnsapikey
PDNS_API_URL=http://powerdns:8081

# ── AI (LLM providers) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
