# ─── Copy this file to .env in the project root ───────────────────────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# (no password by default; set REDIS_PASSWORD for production)

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=changeme_clickhouse

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_TOKEN=dev-root-token
# In production, use AppRole auth — never a root token

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# ── Backup encryption ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=changeme_backup_encryption_key

# ── PowerDNS ──────────────────────────────────────────────────────────────────
PDNS_API_KEY=changeme_pdns_api_key

# ── WebAuthn ──────────────────────────────────────────────────────────────────
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RPID=localhost

# ── OAuth2 Providers (optional) ───────────────────────────────────────────────
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Providers (optional) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_MODEL=claude-sonnet-4-6

# ── Version ───────────────────────────────────────────────────────────────────
VERSION=dev
